# Variables d'environnement attendues par le frontend Vite.
# Copier ce fichier en `.env` (non versionné) et renseigner les vraies valeurs.

# Base URL utilisée par les appels fetch côté React.
# - En dev avec proxy (recommandé, voir VITE_API_PROXY_TARGET ci-dessous) :
#     VITE_API_BASE_URL=/api
# - En dev sans proxy : URL absolue de l'API (nécessite que le serveur API
#   autorise l'origine localhost via CORS — ce n'est pas le cas par défaut) :
#     VITE_API_BASE_URL=https://quadrant.exemple.fr/api
# - En production (frontend servi depuis le même domaine que l'API) :
#     VITE_API_BASE_URL=/api
VITE_API_BASE_URL=/api

# Cible du proxy Vite pour les appels /api/* (dev uniquement).
# Si renseigné, vite.config.js installe un proxy qui redirige /api vers cette
# cible. Permet d'appeler l'API de prod depuis localhost sans CORS.
# Laisser vide ou supprimer pour désactiver le proxy.
VITE_API_PROXY_TARGET=https://quadrant.exemple.fr

# Mode dev : contexte_id passé en query string à chaque appel API.
# Doit correspondre à un id de contexte valide (5 caractères alphanumériques,
# casse mixte). À demander à l'équipe API.
VITE_CONTEXTE_ID_DEV=etBz7
